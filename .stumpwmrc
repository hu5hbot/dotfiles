;; stumpwmrc file
;; @linux.org.ru

(set-font "-misc-fixed-medium-r-normal-*-20-*-*-*-*-*-*-*")

(when *initializing*
	(run-shell-command "feh --bg-fill ~/wallpaper.jpg")
	(grename "term")
	(gnewbg "web")
	(gnewbg "chat")
	(gnewbg "game")
	(gnewbg "music"))	

;; input bar
(set-fg-color "#00cc00")
(set-bg-color "#000000")
(set-msg-border-width 0)
(set-border-color "#000000")
(setf *message-window-gravity* :center
      *input-window-gravity* :center)

;; keys
(define-key *root-map* (kbd "RET")
	    (format nil "exec"))

(define-key *root-map* (kbd "c") "exec urxvt")
(define-key *root-map* (kbd "C") "exec urxvt")
(define-key *root-map* (kbd "B") "mode-line")
(define-key *root-map* (kbd "b") "banish")
(define-key *root-map* (kbd "W") "exec firefox")
(define-key *root-map* (kbd "l") "exec xset s activate")
(define-key *root-map* (kbd "e") "exec urxvt -e vim")
(define-key *root-map* (kbd "C-e") "exec urxvt -e vim")

;; modeline
(setf *group-format* "%t")
(setf *window-format* "%n.%c")
(setf *mode-line-timeout* 1)

(setf *current-song-string* " ")
(setf *time-modeline-string* " ")

(defun get-date-modeline ()
       (stumpwm:run-shell-command
	(format nil "date +%Y.%m.%d_%Hh%Mm%Ss"
		*time-modeline-string*) t))

(setf *screen-mode-line-format*
      (list "%g | %W"
      "^>"
      " "
      '(:eval (get-date-modeline))
      ))

(setf *mode-line-border-width* 1)
(setf *mode-line-background-color* "#000000")
(setf *mode-line-foreground-color* "#00cc00")
(setf *mode-line-border-color*	   "#000000")

;; windows
(setf *window-border-style* :thin)
(setf *border-width* 1)
(set-focus-color "#000000")
